            )
              .map((k) => `<option value="${k}">${k}</option>`)
              .join('')}</select>
          </div>
          <button class="btn-primary" style="flex:0;align-self:flex-end" onclick="addMenu()">+ Создать</button>
        </div>
      </div>
    </div>`;
        const tree = document.getElementById('menu-tree');
        for (const [menuId, menu] of Object.entries(allMenus)) {
          tree.appendChild(renderMenuNode(menuId, menu));
        }
      }

      function renderMenuNode(menuId, menu) {
        const node = document.createElement('div');
        node.className = 'menu-tree-item';
        node.innerHTML = `
    <div class="menu-tree-header" onclick="this.nextElementSibling.classList.toggle('open')">
      <span class="menu-id">${menuId}</span>
      <span style="flex:1;color:#555;font-size:12px;margin-left:8px">${menu.text.slice(0, 50)}${menu.text.length > 50 ? '...' : ''}</span>
      ${menu.parent ? `<span style="font-size:11px;color:#aaa">← ${menu.parent}</span>` : ''}
      <button class="btn-danger" style="margin-left:8px" onclick="event.stopPropagation();deleteMenu('${menuId}')">✕</button>
    </div>
    <div class="menu-tree-body">
      <div style="margin-bottom:8px">
        <div class="form-label" style="margin-bottom:4px">Текст над кнопками</div>
        <div style="display:flex;gap:8px">
          <input class="form-input" style="flex:1" id="menu-text-${menuId}" value="${menu.text.replace(/"/g, '&quot;')}">
          <button class="btn-primary" style="flex:0" onclick="saveMenuText('${menuId}')">Сохранить</button>
        </div>
      </div>
      <div class="pane-label">Кнопки (${menu.buttons.length})</div>
      <div class="btn-list" id="btn-list-${menuId}">
        ${menu.buttons
          .map(
            (btn) => `
          <div class="btn-row" id="btn-${btn.id}">
            <span class="btn-row-label">${btn.label}</span>
            <span class="btn-row-type ${btn.type}">${btn.type}</span>
            <span style="font-size:11px;color:#aaa;font-family:monospace;flex:0;white-space:nowrap">${btn.value.slice(0, 20)}${btn.value.length > 20 ? '...' : ''}</span>
            <button class="btn-move" onclick="moveBtn('${menuId}','${btn.id}','up')" title="Вверх">↑</button>
            <button class="btn-move" onclick="moveBtn('${menuId}','${btn.id}','down')" title="Вниз">↓</button>
            <button class="btn-move" onclick="editBtn('${menuId}','${btn.id}','${btn.label.replace(/'/g, "\\'")}','${btn.type}','${btn.value.replace(/'/g, "\\'")}')">✏️</button>
            <button class="btn-danger" onclick="deleteBtn('${menuId}','${btn.id}')">✕</button>
          </div>`,
          )
          .join('')}
      </div>
      <div class="form-row" style="margin-top:10px">
        <div class="form-group"><div class="form-label">Текст кнопки</div><input class="form-input" id="new-btn-label-${menuId}" placeholder="🏫 Название раздела"></div>
        <div class="form-group" style="flex:0"><div class="form-label">Тип</div>
          <select class="form-select" id="new-btn-type-${menuId}">
            <option value="callback">callback</option>
            <option value="url">url</option>
          </select>
        </div>
        <div class="form-group"><div class="form-label">Значение (ID меню или URL)</div><input class="form-input" id="new-btn-value-${menuId}" placeholder="menu_id или https://..."></div>
        <button class="btn-primary" style="flex:0;align-self:flex-end" onclick="addBtn('${menuId}')">+ Добавить</button>
      </div>
    </div>`;
        return node;
      }

      async function addMenu() {
        const id = document.getElementById('new-menu-id').value.trim();
        const text = document.getElementById('new-menu-text').value.trim();
        const parent = document.getElementById('new-menu-parent').value || null;
        if (!id || !text) {
          showToast('Заполните ID и текст');
          return;
        }
        const r = await fetch('/admin/api/menus', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ id, text, parent }),
        });
        const d = await r.json();
        if (d.ok) {
          showToast('Меню создано');
          await loadMenus();
        } else showToast('Ошибка: ' + d.error);
      }

      async function deleteMenu(menuId) {
        if (!confirm(`Удалить меню "${menuId}"?`)) return;
        const r = await fetch('/admin/api/menus/' + menuId, {
          method: 'DELETE',
        });
        const d = await r.json();
        if (d.ok) {
          showToast('Удалено');
          await loadMenus();
        } else showToast('Ошибка: ' + d.error);
      }

      async function saveMenuText(menuId) {
        const text = document.getElementById('menu-text-' + menuId).value;
        const r = await fetch('/admin/api/menus/' + menuId + '/text', {
          method: 'PUT',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ text }),
        });
        const d = await r.json();
        if (d.ok) showToast('Текст меню сохранён');
        else showToast('Ошибка: ' + d.error);
      }

      async function addBtn(menuId) {
        const label = document
          .getElementById('new-btn-label-' + menuId)
          .value.trim();
        const type = document.getElementById('new-btn-type-' + menuId).value;
        const value = document
          .getElementById('new-btn-value-' + menuId)
          .value.trim();
        if (!label || !value) {
          showToast('Заполните текст и значение кнопки');
          return;
        }
        const r = await fetch('/admin/api/menus/' + menuId + '/buttons', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ label, type, value }),
        });
        const d = await r.json();
        if (d.ok) {
          showToast('Кнопка добавлена');
          await loadMenus();
        } else showToast('Ошибка: ' + d.error);
      }

      async function deleteBtn(menuId, btnId) {
        if (!confirm('Удалить кнопку?')) return;
        const r = await fetch(
          '/admin/api/menus/' + menuId + '/buttons/' + btnId,
          { method: 'DELETE' },
        );
        const d = await r.json();
        if (d.ok) {
          showToast('Кнопка удалена');
          await loadMenus();
        } else showToast('Ошибка: ' + d.error);
      }

      async function moveBtn(menuId, btnId, direction) {
        const r = await fetch(
          '/admin/api/menus/' + menuId + '/buttons/' + btnId + '/move',
          {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ direction }),
          },
        );
        const d = await r.json();
        if (d.ok) await loadMenus();
      }

      function editBtn(menuId, btnId, label, type, value) {
        const newLabel = prompt('Текст кнопки:', label);
        if (newLabel === null) return;
        const newValue = prompt('Значение (ID меню или URL):', value);
        if (newValue === null) return;
        fetch('/admin/api/menus/' + menuId + '/buttons/' + btnId, {
          method: 'PUT',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ label: newLabel, type, value: newValue }),
        })
          .then((r) => r.json())
          .then((d) => {
            if (d.ok) {
              showToast('Кнопка обновлена');
              loadMenus();
            } else showToast('Ошибка: ' + d.error);
          });
      }

      // ========================
      // ADMINS TAB
      // ========================
      async function loadAdmins() {
        try {
          const r = await fetch('/admin/api/admins');
          if (!r.ok) return;
          const admins = await r.json();
          renderAdmins(admins);
        } catch (e) {}
      }

