      // ========================
      // INIT
      // ========================
      async function init() {
        try {
          const r = await fetch('/admin/api/session');
          if (r.status === 401 || r.status === 403) {
            window.location.href = '/admin/login';
            return;
          }
          const session = await r.json();
          currentRole = session.role;
          currentUsername = session.username;
          document.getElementById('role-badge').textContent =
            currentRole === 'superAdmin' ? '⭐ SuperAdmin' : '👤 Admin';
          document.getElementById('role-badge').className =
            'role-badge ' + currentRole;
          if (currentRole === 'superAdmin') {
            document.getElementById('tab-menus').style.display = 'flex';
            document.getElementById('tab-admins').style.display = 'flex';
          }
          await loadContent();
        } catch (e) {
          setStatus('Ошибка подключения', 'error');
        }
      }

      // ========================
      // TABS
      // ========================
      function switchTab(tab) {
        currentTab = tab;
        ['content', 'menus', 'admins'].forEach((t) => {
          document.getElementById('pane-' + t).style.display =
            t === tab ? 'flex' : 'none';
          document
            .getElementById('tab-' + t)
            ?.classList.toggle('active', t === tab);
        });
        if (tab === 'menus' && Object.keys(allMenus).length === 0) loadMenus();
        if (tab === 'admins') loadAdmins();
      }

      // ========================
      // CONTENT TAB
      // ========================
      async function loadContent() {
        try {
          // Загружаем контент и меню одновременно
          const [contentR, menusR] = await Promise.all([
            fetch('/admin/api/content'),
            fetch('/admin/api/menus'),
          ]);
          if (contentR.status === 401) {
            window.location.href = '/admin/login';
            return;
          }
          allContent = await contentR.json();
          if (menusR.ok) {
            allMenus = await menusR.json();
            buildUrlButtons(); // строим карту URL-кнопок
          }
          renderSidebar(allContent);
          setStatus(
            'Данные загружены (' +
              Object.keys(allContent).length +
              ' записей, ' +
              Object.keys(allUrlButtons).length +
              ' URL-кнопок)',
            'ok',
          );
        } catch (e) {
          setStatus('Ошибка загрузки контента', 'error');
        }
      }

      // Строим карту URL-кнопок из menus
      function buildUrlButtons() {
        allUrlButtons = {};
        const menuLabels = {
          main: '🏠 Главное меню',
          contacts: '☎️ Контакты',
          sections: '🏀 Кружки и секции',
        };
        for (const [menuId, menu] of Object.entries(allMenus)) {
          for (const btn of menu.buttons || []) {
            if (btn.type === 'url') {
              const key = 'url::' + menuId + '::' + btn.id;
              allUrlButtons[key] = {
                key,
                label: btn.label,
                url: btn.value,
                menuId,
                btnId: btn.id,
                menuLabel: menuLabels[menuId] || menuId,
              };
            }
          }
        }
      }

      // ========================
      // SIDEBAR
      // ========================
      function renderSidebar(content, query = '') {
        const list = document.getElementById('sidebar-list');
        list.innerHTML = '';

        function matches(text, key) {
          if (!query) return true;
          const q = query.toLowerCase();
          return (
            text.toLowerCase().includes(q) || key.toLowerCase().includes(q)
          );
        }
        function allLeafKeys(node) {
          if (node.items) return node.items.map((i) => i.key);
          if (node.sub) return node.sub.flatMap(allLeafKeys);
          return [];
        }

        // ── СЕКЦИЯ URL-КНОПОК (рендерится первой) ──────────────────
        renderUrlSection(list, query);

        // ── ТЕКСТОВЫЙ КОНТЕНТ (ACCORDION) ──────────────────────────
        for (const group of ACCORDION) {
          const groupKeys = allLeafKeys(group);
          const anyItemInGroup = (k) => {
            const allItems = group.sub
              ? group.sub.flatMap((s) =>
                  s.sub ? s.sub.flatMap((ss) => ss.items) : s.items || [],
                )
              : group.items || [];
            return allItems.find((i) => i.key === k);
          };
          const groupMatch = groupKeys.some((k) => {
            const item = anyItemInGroup(k);
            return item && matches(item.label, k);
          });
          if (query && !groupMatch) continue;

          const isGroupOpen =
            openGroups.has(group.label) || (!!query && groupMatch);
          const groupEl = document.createElement('div');
          groupEl.className = 'acc-group';

          const header = document.createElement('div');
          header.className = 'acc-header' + (isGroupOpen ? ' open' : '');
          header.innerHTML = `<span>${group.label}</span><span class="chevron">▶</span>`;
          const body = document.createElement('div');
          body.className = 'acc-body' + (isGroupOpen ? ' open' : '');
          header.onclick = () => {
            const nowOpen = header.classList.toggle('open');
            body.classList.toggle('open');
            if (nowOpen) openGroups.add(group.label);
            else openGroups.delete(group.label);
          };

          if (group.items) {
            for (const item of group.items) {
              if (query && !matches(item.label, item.key)) continue;
              if (!content[item.key]) continue;
              const el = makeNavItem(item);
              el.classList.add('l1');
              body.appendChild(el);
            }
          } else if (group.sub) {
            for (const sub of group.sub) {
              const subLeafKeys = allLeafKeys(sub);
              const subMatch = subLeafKeys.some((k) => {
                const allItems = sub.sub
                  ? sub.sub.flatMap((ss) => ss.items)
                  : sub.items || [];
                const item = allItems.find((i) => i.key === k);
                return item && matches(item.label, k);
              });
              if (query && !subMatch) continue;

              const isSubOpen =
                openSubs.has(sub.label) || (!!query && subMatch);
              const subHeader = document.createElement('div');
              subHeader.className =
                'acc-sub-header' + (isSubOpen ? ' open' : '');
              subHeader.innerHTML = `<span>${sub.label}</span><span class="chevron">▶</span>`;
              const subBody = document.createElement('div');
              subBody.className = 'acc-sub-body' + (isSubOpen ? ' open' : '');
              subHeader.onclick = () => {
                const nowOpen = subHeader.classList.toggle('open');
                subBody.classList.toggle('open');
                if (nowOpen) openSubs.add(sub.label);
                else openSubs.delete(sub.label);
              };

              if (sub.items) {
                for (const item of sub.items) {
                  if (query && !matches(item.label, item.key)) continue;
                  if (!content[item.key]) continue;
                  subBody.appendChild(makeNavItem(item));
                }
              } else if (sub.sub) {
                for (const ss of sub.sub) {
                  const ssKey = sub.label + '::' + ss.label;
                  const ssMatch = (ss.items || []).some(
                    (i) => matches(i.label, i.key) && content[i.key],
                  );
                  if (query && !ssMatch) continue;

                  const isSSOpen =
                    openSubSubs.has(ssKey) || (!!query && ssMatch);
                  const ssHeader = document.createElement('div');
                  ssHeader.className =
                    'acc-sub-sub-header' + (isSSOpen ? ' open' : '');
                  ssHeader.innerHTML = `<span>${ss.label}</span><span class="chevron">▶</span>`;
                  const ssBody = document.createElement('div');
                  ssBody.className =
                    'acc-sub-sub-body' + (isSSOpen ? ' open' : '');
                  ssHeader.onclick = () => {
                    const nowOpen = ssHeader.classList.toggle('open');
                    ssBody.classList.toggle('open');
                    if (nowOpen) openSubSubs.add(ssKey);
                    else openSubSubs.delete(ssKey);
                  };
                  for (const item of ss.items || []) {
                    if (query && !matches(item.label, item.key)) continue;
                    if (!content[item.key]) continue;
                    const el = makeNavItem(item);
                    el.classList.add('l3');
                    ssBody.appendChild(el);
                  }
                  subBody.appendChild(ssHeader);
                  subBody.appendChild(ssBody);
                }
              }

              body.appendChild(subHeader);
              body.appendChild(subBody);
            }
          }

          groupEl.appendChild(header);
          groupEl.appendChild(body);
          list.appendChild(groupEl);
        }
      }

      // Рендерит секцию URL-кнопок в сайдбар
      function renderUrlSection(list, query) {
        if (Object.keys(allUrlButtons).length === 0) return;

        // Группируем по menuLabel
        const byMenu = {};
        for (const btn of Object.values(allUrlButtons)) {
          if (query && !btn.label.toLowerCase().includes(query.toLowerCase()))
            continue;
          if (!byMenu[btn.menuLabel]) byMenu[btn.menuLabel] = [];
          byMenu[btn.menuLabel].push(btn);
        }
        if (Object.keys(byMenu).length === 0) return;

        const URL_GROUP = '🔗 URL-кнопки';
        const isGroupOpen = openGroups.has(URL_GROUP) || !!query;

        const groupEl = document.createElement('div');
        groupEl.className = 'acc-group';

        const header = document.createElement('div');
        header.className = 'acc-header' + (isGroupOpen ? ' open' : '');
        header.innerHTML = `<span>${URL_GROUP}</span><span class="chevron">▶</span>`;
        const body = document.createElement('div');
        body.className = 'acc-body' + (isGroupOpen ? ' open' : '');
        header.onclick = () => {
          const nowOpen = header.classList.toggle('open');
          body.classList.toggle('open');
          if (nowOpen) openGroups.add(URL_GROUP);
          else openGroups.delete(URL_GROUP);
        };

        for (const [menuLabel, btns] of Object.entries(byMenu)) {
          const subKey = 'url-sub::' + menuLabel;
          const isSubOpen = openSubs.has(subKey) || !!query;

          const subHeader = document.createElement('div');
          subHeader.className = 'acc-sub-header' + (isSubOpen ? ' open' : '');
          subHeader.innerHTML = `<span>${menuLabel}</span><span class="chevron">▶</span>`;
          const subBody = document.createElement('div');
          subBody.className = 'acc-sub-body' + (isSubOpen ? ' open' : '');
          subHeader.onclick = () => {
            const nowOpen = subHeader.classList.toggle('open');
            subBody.classList.toggle('open');
            if (nowOpen) openSubs.add(subKey);
            else openSubs.delete(subKey);
          };

          for (const btn of btns) {
            subBody.appendChild(
              makeNavItem({ key: btn.key, label: btn.label, isUrl: true }),
            );
          }

          body.appendChild(subHeader);
          body.appendChild(subBody);
        }

        groupEl.appendChild(header);
        groupEl.appendChild(body);
        list.appendChild(groupEl);
      }

      // Создаёт элемент навигации (работает для текста и URL)
      function makeNavItem(item) {
        const el = document.createElement('div');
        const isUrl = item.isUrl || (item.key && item.key.startsWith('url::'));
        const isActive = item.key === currentKey;
        const isModified = isUrl ? modifiedUrls[item.key] : modified[item.key];
        el.className =
          'nav-item' +
          (isActive ? ' active' : '') +
          (isModified ? ' modified' : '');
        if (isUrl) {
          el.innerHTML = `<span>${item.label}</span><span class="url-badge">URL</span>`;
        } else {
          el.textContent = item.label;
        }
        el.title = item.key;
        el.onclick = () => {
          selectKey(item.key, item.label);
          closeSidebar();
        };
        return el;
      }

      function filterItems(q) {
        renderSidebar(allContent, q);
      }

      // ========================
      // SELECT KEY
      // ========================
      function selectKey(key, label) {
        if (currentKey === key) return;

        // Проверяем несохранённые изменения
        const isUrlKey = key.startsWith('url::');
        const curIsUrl = currentKey && currentKey.startsWith('url::');
        const wasModified = curIsUrl
          ? modifiedUrls[currentKey]
          : modified[currentKey];
        if (
          currentKey &&
          wasModified &&
          !confirm('Есть несохранённые изменения. Продолжить?')
        )
          return;

        // Авто-раскрываем путь для URL-кнопок
        if (isUrlKey) {
          const urlData = allUrlButtons[key];
          if (urlData) {
            openGroups.add('🔗 URL-кнопки');
            openSubs.add('url-sub::' + urlData.menuLabel);
          }
        }

        // Авто-раскрываем путь для текстового контента
        for (const group of ACCORDION) {
          if (group.items) {
            if (group.items.some((i) => i.key === key))
              openGroups.add(group.label);
          } else if (group.sub) {
            for (const sub of group.sub) {
              if (sub.items && sub.items.some((i) => i.key === key)) {
                openGroups.add(group.label);
                openSubs.add(sub.label);
              } else if (sub.sub) {
                for (const ss of sub.sub) {
                  if ((ss.items || []).some((i) => i.key === key)) {
                    openGroups.add(group.label);
                    openSubs.add(sub.label);
                    openSubSubs.add(sub.label + '::' + ss.label);
                  }
                }
              }
            }
          }
        }

        currentKey = key;
        // В main-key показываем упрощённый ключ для URL
        document.getElementById('main-key').textContent = isUrlKey
          ? key.split('::').slice(1).join(' / ')
          : key;
        document.getElementById('main-title').textContent = label;
        document.getElementById('main-header').style.display = 'flex';
        document.getElementById('empty-state').style.display = 'none';

        if (isUrlKey) {
          // ── URL РЕЖИМ ──────────────────────────────
          document.getElementById('editor-pane').style.display = 'none';
          document.getElementById('preview-pane').style.display = 'none';
          document.getElementById('url-editor-pane').style.display = 'flex';

          const urlData = allUrlButtons[key];
          const urlVal = urlData ? urlData.url : '';
          document.getElementById('url-input').value = urlVal;

          const link = document.getElementById('url-preview-link');
          if (urlVal) {
            link.href = urlVal;
            link.style.display = 'block';
          } else {
            link.style.display = 'none';
          }
        } else {
          // ── ТЕКСТОВЫЙ РЕЖИМ ─────────────────────────
          document.getElementById('url-editor-pane').style.display = 'none';
          document.getElementById('editor-pane').style.display = 'flex';
          if (window.innerWidth > 680)
            document.getElementById('preview-pane').style.display = 'flex';
          document.getElementById('editor').value = allContent[key] || '';
          updatePreview();
          updateCharCount();
        }

        updateSaveBtn();
        renderSidebar(allContent, document.getElementById('search').value);
      }

      // ========================
      // EDIT HANDLERS
      // ========================
      function onEdit() {
        if (!currentKey || currentKey.startsWith('url::')) return;
        const val = document.getElementById('editor').value;
        modified[currentKey] = val !== (allContent[currentKey] || '');
        if (mobilePreviewOpen || window.innerWidth > 680) updatePreview();
        updateCharCount();
        updateSaveBtn();
      }

      function onUrlEdit() {
        if (!currentKey || !currentKey.startsWith('url::')) return;
        const val = document.getElementById('url-input').value.trim();
        const urlData = allUrlButtons[currentKey];
        modifiedUrls[currentKey] = val !== (urlData ? urlData.url : '');

        const link = document.getElementById('url-preview-link');
        if (
          val &&
          (val.startsWith('http') ||
            val.startsWith('vk.') ||
            val.startsWith('t.me'))
        ) {
          link.href = val.startsWith('http') ? val : 'https://' + val;
          link.style.display = 'block';
        } else {
          link.style.display = 'none';
        }
        updateSaveBtn();
      }

      function updatePreview() {
        const val = document.getElementById('editor').value;
        document.getElementById('preview').textContent = val.replace(
          /\*\*(.*?)\*\*/g,
          '$1',
        );
      }

      function updateCharCount() {
        document.getElementById('char-count').textContent =
          document.getElementById('editor').value.length + ' симв.';
      }

      function updateSaveBtn() {
        const btn = document.getElementById('save-btn');
        if (currentKey && currentKey.startsWith('url::')) {
          btn.disabled = !modifiedUrls[currentKey];
        } else {
          btn.disabled = !currentKey || !modified[currentKey];
        }
        btn.textContent = 'Сохранить';
        btn.className = 'btn-primary';
      }

      // ========================
      // SAVE
      // ========================
      async function saveContent() {
        if (!currentKey) return;

        const btn = document.getElementById('save-btn');
        btn.disabled = true;
        btn.textContent = 'Сохраняю...';

        // ── СОХРАНЕНИЕ URL-КНОПКИ ──────────────────────
        if (currentKey.startsWith('url::')) {
          const urlData = allUrlButtons[currentKey];
          if (!urlData) return;
          const newUrl = document.getElementById('url-input').value.trim();
          if (!newUrl) {
            showToast('URL не может быть пустым');
            btn.disabled = false;
            btn.textContent = 'Сохранить';
            return;
          }

          try {
            const r = await fetch(
              '/admin/api/menus/' +
                urlData.menuId +
                '/buttons/' +
                urlData.btnId,
              {
                method: 'PUT',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                  label: urlData.label,
                  type: 'url',
                  value: newUrl,
                }),
              },
            );
            if (r.status === 401) {
              window.location.href = '/admin/login';
              return;
            }
            if (r.ok) {
              urlData.url = newUrl; // обновляем кэш
              delete modifiedUrls[currentKey];

              const link = document.getElementById('url-preview-link');
              link.href = newUrl.startsWith('http')
                ? newUrl
                : 'https://' + newUrl;
              link.style.display = 'block';

              btn.textContent = 'Сохранено ✓';
              btn.className = 'btn-primary saved';
              showToast('Ссылка сохранена ✓');
              setStatus('Сохранено: ' + urlData.label, 'ok');
              renderSidebar(
                allContent,
                document.getElementById('search').value,
              );
              setTimeout(() => {
                btn.textContent = 'Сохранить';
                btn.className = 'btn-primary';
                btn.disabled = true;
              }, 2000);
            } else throw new Error('Ошибка API');
          } catch {
            btn.textContent = 'Ошибка ✗';
            btn.className = 'btn-primary error-state';
            btn.disabled = false;
            showToast('Ошибка сохранения!');
            setTimeout(() => {
              btn.textContent = 'Сохранить';
              btn.className = 'btn-primary';
            }, 3000);
          }
          return;
        }

        // ── СОХРАНЕНИЕ ТЕКСТОВОГО КОНТЕНТА ─────────────
        const value = document.getElementById('editor').value;
        try {
          const r = await fetch(
            '/admin/api/content/' + encodeURIComponent(currentKey),
            {
              method: 'PUT',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ value }),
            },
          );
          if (r.status === 401) {
            window.location.href = '/admin/login';
            return;
          }
          if (r.ok) {
            allContent[currentKey] = value;
            delete modified[currentKey];
            btn.textContent = 'Сохранено ✓';
            btn.className = 'btn-primary saved';
            showToast('Сохранено ✓');
            setStatus('Сохранено: ' + currentKey, 'ok');
            renderSidebar(allContent, document.getElementById('search').value);
            setTimeout(() => {
              btn.textContent = 'Сохранить';
              btn.className = 'btn-primary';
              btn.disabled = true;
            }, 2000);
          } else throw new Error();
        } catch {
          btn.textContent = 'Ошибка ✗';
          btn.className = 'btn-primary error-state';
          btn.disabled = false;
          showToast('Ошибка сохранения!');
          setTimeout(() => {
            btn.textContent = 'Сохранить';
            btn.className = 'btn-primary';
          }, 3000);
        }
      }

      // ========================
      // MENUS TAB
      // ========================
      async function loadMenus() {
        try {
          const r = await fetch('/admin/api/menus');
          if (!r.ok) return;
          allMenus = await r.json();
          renderMenus();
        } catch (e) {}
      }

      function renderMenus() {
        const panel = document.getElementById('menus-panel');
        panel.innerHTML = `
    <div class="panel-section">
      <div class="panel-section-header">
        Структура меню бота
        <span style="font-size:11px;color:#aaa;font-weight:400">Кликните на меню для редактирования</span>
      </div>
      <div class="panel-section-body" id="menu-tree"></div>
    </div>
    <div class="panel-section">
      <div class="panel-section-header">Добавить новое меню</div>
      <div class="panel-section-body">
        <div class="form-row">
          <div class="form-group"><div class="form-label">ID меню (уникальный, латиница)</div><input class="form-input" id="new-menu-id" placeholder="например: my_custom_menu"></div>
          <div class="form-group"><div class="form-label">Текст над кнопками</div><input class="form-input" id="new-menu-text" placeholder="Выберите раздел:"></div>
          <div class="form-group" style="flex:0"><div class="form-label">Родитель</div>
