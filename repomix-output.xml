      // ========================
      // INIT
      // ========================
      async function init() {
        try {
          const r = await fetch('/admin/api/session');
          if (r.status === 401 || r.status === 403) {
            window.location.href = '/admin/login';
            return;
          }
          const session = await r.json();
          currentRole = session.role;
          currentUsername = session.username;
          document.getElementById('role-badge').textContent =
            currentRole === 'superAdmin' ? '⭐ SuperAdmin' : '👤 Admin';
          document.getElementById('role-badge').className =
            'role-badge ' + currentRole;

          if (currentRole === 'superAdmin') {
            document.getElementById('tab-menus').style.display = 'flex';
            document.getElementById('tab-admins').style.display = 'flex';
          }
          await loadContent();
        } catch (e) {
          setStatus('Ошибка подключения', 'error');
        }
      }

      // ========================
      // TABS
      // ========================
      function switchTab(tab) {
        currentTab = tab;
        ['content', 'menus', 'admins'].forEach((t) => {
          document.getElementById('pane-' + t).style.display =
            t === tab ? 'flex' : 'none';
          document
            .getElementById('tab-' + t)
            ?.classList.toggle('active', t === tab);
        });
        if (tab === 'menus' && Object.keys(allMenus).length === 0) loadMenus();
        if (tab === 'admins') loadAdmins();
      }

      // ========================
      // CONTENT TAB
      // ========================
      async function loadContent() {
        try {
          const r = await fetch('/admin/api/content');
          if (r.status === 401) {
            window.location.href = '/admin/login';
            return;
          }
          allContent = await r.json();
          renderSidebar(allContent);
          setStatus(
            'Данные загружены (' + Object.keys(allContent).length + ' записей)',
            'ok',
          );
        } catch (e) {
          setStatus('Ошибка загрузки контента', 'error');
        }
      }

      function renderSidebar(content, query = '') {
        const list = document.getElementById('sidebar-list');
        list.innerHTML = '';

        for (const group of ACCORDION) {
          const groupEl = document.createElement('div');
          groupEl.className = 'acc-group';

          // Собираем все ключи группы
          const allKeys = group.sub
            ? group.sub.flatMap((s) => s.items.map((i) => i.key))
            : (group.items || []).map((i) => i.key);

          const matchKeys = allKeys.filter((k) => {
            if (!query) return true;
            const item = (
              group.sub ? group.sub.flatMap((s) => s.items) : group.items
            ).find((i) => i.key === k);
            return (
              item &&
              (item.label.toLowerCase().includes(query.toLowerCase()) ||
                k.includes(query.toLowerCase()))
            );
          });

          if (query && matchKeys.length === 0) continue;

          const header = document.createElement('div');
          header.className = 'acc-header' + (!query ? ' open' : '');
          header.innerHTML = `<span>${group.label}</span><span class="chevron">▶</span>`;
          header.onclick = () => {
            header.classList.toggle('open');
            body.classList.toggle('open');
          };
          groupEl.appendChild(header);

          const body = document.createElement('div');
          body.className = 'acc-body' + (!query ? ' open' : '');

          if (group.sub) {
            // 3-level: group → sub → items
            for (const sub of group.sub) {
              const subKeys = sub.items
                .map((i) => i.key)
                .filter((k) => {
                  if (!query) return true;
                  const item = sub.items.find((i) => i.key === k);
                  return (
                    item &&
                    (item.label.toLowerCase().includes(query.toLowerCase()) ||
                      k.includes(query.toLowerCase()))
                  );
                });
              if (query && subKeys.length === 0) continue;

              const subHeader = document.createElement('div');
              subHeader.className = 'acc-sub-header' + (!query ? ' open' : '');
              subHeader.innerHTML = `<span>${sub.label}</span><span class="chevron">▶</span>`;
              const subBody = document.createElement('div');
              subBody.className = 'acc-sub-body' + (!query ? ' open' : '');
              subHeader.onclick = () => {
                subHeader.classList.toggle('open');
                subBody.classList.toggle('open');
              };

              for (const item of sub.items) {
                if (
                  query &&
                  !item.label.toLowerCase().includes(query.toLowerCase()) &&
                  !item.key.includes(query.toLowerCase())
                )
                  continue;
                if (!content[item.key]) continue;
                subBody.appendChild(makeNavItem(item));
              }

              body.appendChild(subHeader);
              body.appendChild(subBody);
            }
          } else {
            // 2-level: group → items
            for (const item of group.items || []) {
              if (
                query &&
                !item.label.toLowerCase().includes(query.toLowerCase()) &&
                !item.key.includes(query.toLowerCase())
              )
                continue;
              if (!content[item.key]) continue;
              const el = makeNavItem(item);
              el.classList.add('l1');
              body.appendChild(el);
            }
          }

          groupEl.appendChild(body);
          list.appendChild(groupEl);
        }
      }

      function makeNavItem(item) {
        const el = document.createElement('div');
        el.className =
          'nav-item' +
          (item.key === currentKey ? ' active' : '') +
          (modified[item.key] ? ' modified' : '');
        el.textContent = item.label;
        el.title = item.key;
        el.onclick = () => {
          selectKey(item.key, item.label);
          closeSidebar();
        };
        return el;
      }

      function filterItems(q) {
        renderSidebar(allContent, q);
      }

      function selectKey(key, label) {
        if (currentKey === key) return;
        if (
          currentKey &&
          modified[currentKey] &&
          !confirm('Есть несохранённые изменения. Продолжить?')
        )
          return;
        currentKey = key;
        document.getElementById('editor').value = allContent[key] || '';
        document.getElementById('main-key').textContent = key;
        document.getElementById('main-title').textContent = label;
        document.getElementById('main-header').style.display = 'flex';
        document.getElementById('editor-pane').style.display = 'flex';
        document.getElementById('empty-state').style.display = 'none';
        if (window.innerWidth > 680)
          document.getElementById('preview-pane').style.display = 'flex';
        updatePreview();
        updateCharCount();
        updateSaveBtn();
        renderSidebar(allContent, document.getElementById('search').value);
      }

      function onEdit() {
        const val = document.getElementById('editor').value;
        if (currentKey)
          modified[currentKey] = val !== (allContent[currentKey] || '');
        if (mobilePreviewOpen || window.innerWidth > 680) updatePreview();
        updateCharCount();
        updateSaveBtn();
      }

      function updatePreview() {
        const val = document.getElementById('editor').value;
        document.getElementById('preview').textContent = val.replace(
          /\*\*(.*?)\*\*/g,
          '$1',
        );
      }

      function updateCharCount() {
        document.getElementById('char-count').textContent =
          document.getElementById('editor').value.length + ' симв.';
      }

      function updateSaveBtn() {
        const btn = document.getElementById('save-btn');
        btn.disabled = !currentKey || !modified[currentKey];
        btn.textContent = 'Сохранить';
        btn.className = 'btn-primary';
      }

      async function saveContent() {
        if (!currentKey) return;
        const value = document.getElementById('editor').value;
        const btn = document.getElementById('save-btn');
        btn.disabled = true;
        btn.textContent = 'Сохраняю...';
        try {
          const r = await fetch(
            '/admin/api/content/' + encodeURIComponent(currentKey),
            {
              method: 'PUT',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ value }),
            },
          );
          if (r.status === 401) {
            window.location.href = '/admin/login';
            return;
          }
          if (r.ok) {
            allContent[currentKey] = value;
            delete modified[currentKey];
            btn.textContent = 'Сохранено ✓';
            btn.className = 'btn-primary saved';
            showToast('Сохранено ✓');
            setStatus('Сохранено: ' + currentKey, 'ok');
            renderSidebar(allContent, document.getElementById('search').value);
            setTimeout(() => {
              btn.textContent = 'Сохранить';
              btn.className = 'btn-primary';
              btn.disabled = true;
            }, 2000);
          } else throw new Error();
        } catch {
          btn.textContent = 'Ошибка ✗';
          btn.className = 'btn-primary error-state';
          btn.disabled = false;
          showToast('Ошибка сохранения!');
          setTimeout(() => {
            btn.textContent = 'Сохранить';
            btn.className = 'btn-primary';
          }, 3000);
        }
      }

      // ========================
      // MENUS TAB
      // ========================
      async function loadMenus() {
        try {
          const r = await fetch('/admin/api/menus');
          if (!r.ok) return;
          allMenus = await r.json();
          renderMenus();
        } catch (e) {}
      }

      function renderMenus() {
        const panel = document.getElementById('menus-panel');
        panel.innerHTML = `
    <div class="panel-section">
      <div class="panel-section-header">
        Структура меню бота
        <span style="font-size:11px;color:#aaa;font-weight:400">Кликните на меню для редактирования</span>
      </div>
      <div class="panel-section-body" id="menu-tree"></div>
    </div>
    <div class="panel-section">
      <div class="panel-section-header">Добавить новое меню</div>
      <div class="panel-section-body">
        <div class="form-row">
          <div class="form-group"><div class="form-label">ID меню (уникальный, латиница)</div><input class="form-input" id="new-menu-id" placeholder="например: my_custom_menu"></div>
          <div class="form-group"><div class="form-label">Текст над кнопками</div><input class="form-input" id="new-menu-text" placeholder="Выберите раздел:"></div>
          <div class="form-group" style="flex:0"><div class="form-label">Родитель</div>
            <select class="form-select" id="new-menu-parent"><option value="">нет</option>${Object.keys(
              allMenus,
            )
              .map((k) => `<option value="${k}">${k}</option>`)
              .join('')}</select>
          </div>
          <button class="btn-primary" style="flex:0;align-self:flex-end" onclick="addMenu()">+ Создать</button>
        </div>
      </div>
    </div>
  `;

        const tree = document.getElementById('menu-tree');
        for (const [menuId, menu] of Object.entries(allMenus)) {
          tree.appendChild(renderMenuNode(menuId, menu));
        }
      }

      function renderMenuNode(menuId, menu) {
        const node = document.createElement('div');
        node.className = 'menu-tree-item';
        node.innerHTML = `
    <div class="menu-tree-header" onclick="this.nextElementSibling.classList.toggle('open')">
      <span class="menu-id">${menuId}</span>
      <span style="flex:1;color:#555;font-size:12px;margin-left:8px">${menu.text.slice(0, 50)}${menu.text.length > 50 ? '...' : ''}</span>
      ${menu.parent ? `<span style="font-size:11px;color:#aaa">← ${menu.parent}</span>` : ''}
      <button class="btn-danger" style="margin-left:8px" onclick="event.stopPropagation();deleteMenu('${menuId}')">✕</button>
    </div>
    <div class="menu-tree-body">
      <div style="margin-bottom:8px">
        <div class="form-label" style="margin-bottom:4px">Текст над кнопками</div>
        <div style="display:flex;gap:8px">
          <input class="form-input" style="flex:1" id="menu-text-${menuId}" value="${menu.text.replace(/"/g, '&quot;')}">
          <button class="btn-primary" style="flex:0" onclick="saveMenuText('${menuId}')">Сохранить</button>
        </div>
      </div>
      <div class="pane-label">Кнопки (${menu.buttons.length})</div>
      <div class="btn-list" id="btn-list-${menuId}">
        ${menu.buttons
          .map(
            (btn) => `
          <div class="btn-row" id="btn-${btn.id}">
            <span class="btn-row-label">${btn.label}</span>
            <span class="btn-row-type ${btn.type}">${btn.type}</span>
            <span style="font-size:11px;color:#aaa;font-family:monospace;flex:0;white-space:nowrap">${btn.value.slice(0, 20)}${btn.value.length > 20 ? '...' : ''}</span>
            <button class="btn-move" onclick="moveBtn('${menuId}','${btn.id}','up')" title="Вверх">↑</button>
            <button class="btn-move" onclick="moveBtn('${menuId}','${btn.id}','down')" title="Вниз">↓</button>
            <button class="btn-move" onclick="editBtn('${menuId}','${btn.id}','${btn.label.replace(/'/g, "\\'")}','${btn.type}','${btn.value.replace(/'/g, "\\'")}')">✏️</button>
            <button class="btn-danger" onclick="deleteBtn('${menuId}','${btn.id}')">✕</button>
          </div>`,
          )
          .join('')}
      </div>
      <div class="form-row" style="margin-top:10px">
        <div class="form-group"><div class="form-label">Текст кнопки</div><input class="form-input" id="new-btn-label-${menuId}" placeholder="🏫 Название раздела"></div>
        <div class="form-group" style="flex:0"><div class="form-label">Тип</div>
          <select class="form-select" id="new-btn-type-${menuId}">
            <option value="callback">callback</option>
            <option value="url">url</option>
          </select>
        </div>
        <div class="form-group"><div class="form-label">Значение (ID меню или URL)</div><input class="form-input" id="new-btn-value-${menuId}" placeholder="menu_id или https://..."></div>
        <button class="btn-primary" style="flex:0;align-self:flex-end" onclick="addBtn('${menuId}')">+ Добавить</button>
      </div>
    </div>`;
        return node;
      }

      async function addMenu() {
        const id = document.getElementById('new-menu-id').value.trim();
        const text = document.getElementById('new-menu-text').value.trim();
        const parent = document.getElementById('new-menu-parent').value || null;
        if (!id || !text) {
          showToast('Заполните ID и текст');
          return;
        }
        const r = await fetch('/admin/api/menus', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ id, text, parent }),
        });
        const d = await r.json();
        if (d.ok) {
          showToast('Меню создано');
          await loadMenus();
        } else showToast('Ошибка: ' + d.error);
      }

      async function deleteMenu(menuId) {
        if (
          !confirm(
            `Удалить меню "${menuId}"? Кнопки из других меню, ссылающиеся на него, тоже удалятся.`,
          )
        )
          return;
        const r = await fetch('/admin/api/menus/' + menuId, {
          method: 'DELETE',
        });
        const d = await r.json();
        if (d.ok) {
          showToast('Удалено');
          await loadMenus();
        } else showToast('Ошибка: ' + d.error);
      }

      async function saveMenuText(menuId) {
        const text = document.getElementById('menu-text-' + menuId).value;
        const r = await fetch('/admin/api/menus/' + menuId + '/text', {
          method: 'PUT',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ text }),
        });
        const d = await r.json();
        if (d.ok) showToast('Текст меню сохранён');
        else showToast('Ошибка: ' + d.error);
      }

      async function addBtn(menuId) {
        const label = document
          .getElementById('new-btn-label-' + menuId)
          .value.trim();
        const type = document.getElementById('new-btn-type-' + menuId).value;
        const value = document
          .getElementById('new-btn-value-' + menuId)
          .value.trim();
        if (!label || !value) {
          showToast('Заполните текст и значение кнопки');
          return;
        }
        const r = await fetch('/admin/api/menus/' + menuId + '/buttons', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ label, type, value }),
        });
        const d = await r.json();
        if (d.ok) {
          showToast('Кнопка добавлена');
          await loadMenus();
        } else showToast('Ошибка: ' + d.error);
      }

      async function deleteBtn(menuId, btnId) {
        if (!confirm('Удалить кнопку?')) return;
        const r = await fetch(
          '/admin/api/menus/' + menuId + '/buttons/' + btnId,
          { method: 'DELETE' },
        );
        const d = await r.json();
        if (d.ok) {
          showToast('Кнопка удалена');
          await loadMenus();
        } else showToast('Ошибка: ' + d.error);
      }

      async function moveBtn(menuId, btnId, direction) {
        const r = await fetch(
          '/admin/api/menus/' + menuId + '/buttons/' + btnId + '/move',
          {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ direction }),
          },
        );
        const d = await r.json();
        if (d.ok) await loadMenus();
      }

      function editBtn(menuId, btnId, label, type, value) {
        const newLabel = prompt('Текст кнопки:', label);
        if (newLabel === null) return;
        const newValue = prompt('Значение (ID меню или URL):', value);
        if (newValue === null) return;
        fetch('/admin/api/menus/' + menuId + '/buttons/' + btnId, {
          method: 'PUT',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ label: newLabel, type, value: newValue }),
        })
          .then((r) => r.json())
          .then((d) => {
            if (d.ok) {
              showToast('Кнопка обновлена');
              loadMenus();
            } else showToast('Ошибка: ' + d.error);
          });
      }

      // ========================
      // ADMINS TAB
      // ========================
      async function loadAdmins() {
        try {
          const r = await fetch('/admin/api/admins');
          if (!r.ok) return;
          const admins = await r.json();
          renderAdmins(admins);
        } catch (e) {}
      }

      function renderAdmins(admins) {
        const panel = document.getElementById('admins-panel');
        const superName = '(из .env)';
        panel.innerHTML = `
    <div class="panel-section">
      <div class="panel-section-header">SuperAdmin</div>
      <div class="panel-section-body">
        <div class="admin-row">
          <span class="admin-role-badge" style="background:#fef3c7;color:#92400e">⭐ superAdmin</span>
          <span class="admin-row-name">${currentRole === 'superAdmin' ? currentUsername : '***'}</span>
          <span class="admin-row-date">${superName}</span>
        </div>
      </div>
    </div>
    <div class="panel-section">
      <div class="panel-section-header">
        Администраторы
        <span style="font-size:11px;color:#aaa;font-weight:400">${admins.length} чел.</span>
      </div>
      <div class="panel-section-body">
        ${
          admins.length === 0
            ? '<p style="color:#aaa;font-size:13px">Пока нет ни одного администратора</p>'
            : admins
                .map(
                  (u) => `
            <div class="admin-row">
              <span class="admin-role-badge">admin</span>
              <span class="admin-row-name">${u.username}</span>
              <span class="admin-row-date">${new Date(u.createdAt).toLocaleDateString('ru-RU')}</span>
              <button class="btn-secondary" style="font-size:12px;padding:4px 10px" onclick="changePass('${u.id}','${u.username}')">Пароль</button>
              <button class="btn-danger" onclick="deleteAdmin('${u.id}','${u.username}')">Удалить</button>
            </div>`,
                )
                .join('')
        }
      </div>
    </div>
    <div class="panel-section">
      <div class="panel-section-header">Добавить администратора</div>
      <div class="panel-section-body">
        <div class="form-row">
          <div class="form-group"><div class="form-label">Имя пользователя</div><input class="form-input" id="new-admin-name" placeholder="Имя без пробелов"></div>
          <div class="form-group"><div class="form-label">Пароль</div><input class="form-input" type="password" id="new-admin-pass" placeholder="Минимум 6 символов"></div>
          <button class="btn-primary" style="flex:0;align-self:flex-end" onclick="createAdmin()">+ Добавить</button>
        </div>
      </div>
    </div>`;
      }

      async function createAdmin() {
        const username = document.getElementById('new-admin-name').value.trim();
        const password = document.getElementById('new-admin-pass').value;
        if (!username || !password) {
          showToast('Заполните имя и пароль');
          return;
        }
        if (password.length < 6) {
          showToast('Пароль минимум 6 символов');
          return;
        }
        const r = await fetch('/admin/api/admins', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ username, password }),
        });
        const d = await r.json();
        if (d.ok) {
          showToast('Администратор создан');
          await loadAdmins();
        } else showToast('Ошибка: ' + d.error);
      }

      async function deleteAdmin(id, name) {
        if (!confirm(`Удалить администратора "${name}"?`)) return;
        const r = await fetch('/admin/api/admins/' + id, { method: 'DELETE' });
        const d = await r.json();
        if (d.ok) {
          showToast('Удалено');
          await loadAdmins();
        } else showToast('Ошибка: ' + d.error);
      }

      async function changePass(id, name) {
        const newPass = prompt(`Новый пароль для "${name}":`);
        if (!newPass || newPass.length < 6) {
          if (newPass !== null) showToast('Пароль минимум 6 символов');
          return;
        }
        const r = await fetch('/admin/api/admins/' + id + '/password', {
          method: 'PUT',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ password: newPass }),
        });
        const d = await r.json();
        if (d.ok) showToast('Пароль изменён');
        else showToast('Ошибка: ' + d.error);
      }

      // ========================
      // SIDEBAR MOBILE
      // ========================
      function toggleSidebar() {
        sidebarOpen ? closeSidebar() : openSidebar();
      }
      function openSidebar() {
        sidebarOpen = true;
        document.getElementById('sidebar').classList.add('open');
        document.getElementById('overlay').classList.add('show');
        document.getElementById('menu-btn').classList.add('open');
      }
      function closeSidebar() {
        sidebarOpen = false;
        document.getElementById('sidebar').classList.remove('open');
        document.getElementById('overlay').classList.remove('show');
        document.getElementById('menu-btn').classList.remove('open');
      }

      // ========================
      // PREVIEW MOBILE
      // ========================
      function toggleMobilePreview() {
        mobilePreviewOpen ? closeMobilePreview() : openMobilePreview();
      }
      function openMobilePreview() {
        mobilePreviewOpen = true;
        updatePreview();
        const p = document.getElementById('preview-pane');
        p.style.display = 'flex';
        p.classList.add('mobile-show');
        document.getElementById('close-preview-btn').style.display = 'block';
        document.getElementById('preview-toggle').classList.add('active');
        document.getElementById('preview-toggle').textContent = 'Закрыть';
      }
      function closeMobilePreview() {
        mobilePreviewOpen = false;
        const p = document.getElementById('preview-pane');
        p.classList.remove('mobile-show');
        if (window.innerWidth > 680 && currentKey) p.style.display = 'flex';
        else p.style.display = 'none';
        document.getElementById('close-preview-btn').style.display = 'none';
        document.getElementById('preview-toggle').classList.remove('active');
        document.getElementById('preview-toggle').textContent = 'Просмотр';
      }
      window.addEventListener('resize', () => {
        if (window.innerWidth > 680 && currentKey) {
          const p = document.getElementById('preview-pane');
          p.style.display = 'flex';
          p.classList.remove('mobile-show');
          mobilePreviewOpen = false;
        }
      });

      // ========================
      // UTILITIES
      // ========================
      async function logout() {
        await fetch('/admin/logout', { method: 'POST' });
        window.location.href = '/admin/login';
      }

      function setStatus(text, type = 'ok') {
        document.getElementById('status-text').textContent = text;
        document.getElementById('status-dot').className =
          'status-dot' +
          (type === 'error' ? ' error' : type === 'warn' ? ' warn' : '');
      }

      let toastTimer;
      function showToast(msg) {
        const t = document.getElementById('toast');
        t.textContent = msg;
        t.classList.add('show');
        clearTimeout(toastTimer);
        toastTimer = setTimeout(() => t.classList.remove('show'), 2500);
      }

      document.addEventListener('keydown', (e) => {
        if ((e.ctrlKey || e.metaKey) && e.key === 's') {
          e.preventDefault();
          if (currentKey && modified[currentKey]) saveContent();
        }
        if (e.key === 'Escape') {
          if (mobilePreviewOpen) closeMobilePreview();
          if (sidebarOpen) closeSidebar();
        }
      });

      init();
    </script>
  </body>
</html>
